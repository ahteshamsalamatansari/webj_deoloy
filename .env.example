# ══════════════════════════════════════════════════════════════════
#  Webjet Scraper — Environment Variables
#
#  LOCAL DEV  : Copy this file to .env and fill in your values.
#               pip install python-dotenv  then load with dotenv.
#
#  RENDER.COM : Do NOT commit .env to GitHub.
#               Set these in the Render dashboard →
#               Your Service → Environment → Add Environment Variable.
#               Mark BD_BROWSER_USER and BD_BROWSER_PASS as "Secret".
# ══════════════════════════════════════════════════════════════════


# ── Bright Data Scraping Browser API ──────────────────────────────
# Find these in your Bright Data dashboard under the zone settings.

BD_BROWSER_HOST=brd.superproxy.io
BD_BROWSER_PORT=9222
BD_BROWSER_USER=brd-customer-hl_fbc4a16a-zone-cont_rex
BD_BROWSER_PASS=your_bright_data_password_here

# Optional: override the full WebSocket URL directly.
# Leave blank — it is auto-built from the four values above.
# BD_BROWSER_WSS=wss://USER:PASS@brd.superproxy.io:9222


# ── Timezone ───────────────────────────────────────────────────────
REX_TIMEZONE=Australia/Perth


# ── Output paths ───────────────────────────────────────────────────
# Render.com cron jobs have an EPHEMERAL filesystem.
# Files written outside the persistent disk are deleted after each run.
# The render.yaml mounts a persistent disk at /data — use those paths
# on Render so the Excel file and resume state survive between daily runs.
#
# Render.com (persistent disk — matches render.yaml):
#   WJ_OUTPUT_EXCEL=/data/webjet_results.xlsx
#   WJ_LOG_DIR=/data/webjet_logs
#   WJ_DEBUG_DIR=/data/webjet_debug
#
# Local development:
WJ_OUTPUT_EXCEL=webjet_results.xlsx
WJ_LOG_DIR=webjet_logs
WJ_DEBUG_DIR=webjet_debug


# ── Scraper settings ───────────────────────────────────────────────
WJ_TOTAL_DAYS=84
WJ_START_OFFSET_DAYS=1

# Retry / timeout
WJ_MAX_ATTEMPTS=3
WJ_FINAL_RETRY_ROUNDS=1
WJ_RETRY_BACKOFF_SECONDS=8
WJ_MAX_RETRY_BACKOFF_SECONDS=90
WJ_JOB_TIMEOUT_SECONDS=240
WJ_PAGE_LOAD_TIMEOUT=90


# ── Resume / checkpoint ────────────────────────────────────────────
# WJ_RESUME=1  →  skip dates already recorded as SUCCESS or NO_FARE
#               for today's Run ID (safe to re-run if interrupted).
# WJ_RESUME=0  →  re-scrape everything from scratch.
WJ_RESUME=1
WJ_CHECKPOINT_EVERY=7
WJ_INTER_ROUTE_DELAY_SECONDS=30


# ── Email report (optional) ────────────────────────────────────────
# Leave EMAIL_SENDER blank to disable emailing entirely.
#
# Gmail setup:
#   1. Enable 2-Step Verification on the sender Gmail account.
#   2. Go to Google Account → Security → App Passwords.
#   3. Create an App Password for "Mail" / "Other" → copy the 16-char code.
#   4. Paste it as EMAIL_PASSWORD below (no spaces).
#
# EMAIL_RECIPIENT can be a single address or comma-separated list.

EMAIL_SENDER=your_sender@gmail.com
EMAIL_PASSWORD=abcd efgh ijkl mnop   # 16-char Google App Password
EMAIL_RECIPIENT=client@example.com
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SUBJECT_PREFIX=Webjet Scraper
